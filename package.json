{
  "name": "pos-restaurante",
  "version": "1.0.0",
  "description": "Sistema POS para restaurantes pequeños — Colombia",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n VITE,ELECTRON -c cyan,yellow \"vite\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "build:react": "vite build",
    "rebuild:sqlite": "electron-rebuild -f -w better-sqlite3",
    "build": "npm run rebuild:sqlite && npm run build:react && electron-builder",
    "preview": "vite preview",
    "clean:all": "powershell -Command \"Remove-Item -Recurse -Force dist, release, $env:APPDATA\\pos-restaurante, $env:LOCALAPPDATA\\Programs\\pos-restaurante -ErrorAction SilentlyContinue\""
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "vite": "^5.3.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.pos.restaurante",
    "productName": "POS Restaurante",
    "copyright": "Copyright © 2024",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "resources/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "POS Restaurante"
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*",
      "**/node_modules/bindings/**/*"
    ]
  }
}